<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    
    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- 文件输出 - 按日期分目录 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 日志文件按 yyyy/MM/dd 目录结构存储 -->
            <fileNamePattern>logs/%d{yyyy/MM/dd}/wechat-collector.log</fileNamePattern>
            <!-- 保留30天的日志 -->
            <maxHistory>30</maxHistory>
            <!-- 总大小限制 1GB -->
            <totalSizeCap>1GB</totalSizeCap>
            <!-- 启动时自动清理过期日志 -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- 错误日志单独输出 - 按日期分目录 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 错误日志文件按 yyyy/MM/dd 目录结构存储 -->
            <fileNamePattern>logs/%d{yyyy/MM/dd}/error.log</fileNamePattern>
            <!-- 保留30天的日志 -->
            <maxHistory>30</maxHistory>
            <!-- 启动时自动清理过期日志 -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- 会话提醒服务日志 - 独立目录按日期存储 -->
    <appender name="CONVERSATION_REMINDER_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 日志文件按 conversation-reminder/yyyy/MM/dd 目录结构存储 -->
            <fileNamePattern>logs/conversation-reminder/%d{yyyy/MM/dd}/reminder.log</fileNamePattern>
            <!-- 保留30天的日志 -->
            <maxHistory>30</maxHistory>
            <!-- 总大小限制 500MB -->
            <totalSizeCap>500MB</totalSizeCap>
            <!-- 启动时自动清理过期日志 -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- 情绪分析服务日志 - 独立目录按日期存储 -->
    <appender name="SENTIMENT_ANALYSIS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 日志文件按 sentiment-analysis/yyyy/MM/dd 目录结构存储 -->
            <fileNamePattern>logs/sentiment-analysis/%d{yyyy/MM/dd}/sentiment.log</fileNamePattern>
            <!-- 保留30天的日志 -->
            <maxHistory>30</maxHistory>
            <!-- 总大小限制 500MB -->
            <totalSizeCap>500MB</totalSizeCap>
            <!-- 启动时自动清理过期日志 -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- 会话提醒服务 - 独立日志配置 -->
    <logger name="com.wechat.collector.service.ConversationReminderService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="CONVERSATION_REMINDER_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>
    
    <logger name="com.wechat.collector.service.ConversationReminderScheduler" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="CONVERSATION_REMINDER_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>
    
    <!-- 情绪分析服务 - 独立日志配置 -->
    <logger name="com.wechat.collector.service.SentimentAnalysisService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="SENTIMENT_ANALYSIS_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>
    
    <logger name="com.wechat.collector.service.SentimentAnalysisApiService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="SENTIMENT_ANALYSIS_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>
    
    <logger name="com.wechat.collector.service.SentimentAnalysisScheduler" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="SENTIMENT_ANALYSIS_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>
    
    <logger name="com.wechat.collector.service.GeminiService" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="SENTIMENT_ANALYSIS_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>
    
    <!-- 应用日志级别 -->
    <logger name="com.wechat.collector" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </logger>
    
    <!-- Javalin 日志级别 -->
    <logger name="io.javalin" level="INFO"/>
    
    <!-- HikariCP 日志级别 -->
    <logger name="com.zaxxer.hikari" level="INFO"/>
    
    <!-- 根日志级别 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>
    
</configuration>

